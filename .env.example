DEBUG=true
APP_NAME=BreadTestingBE

JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=10
ADMIN_PASSWORD=admin123

# MySQL（可用 docker compose up -d 启动）
# 数据持久化目录：./data/mysql（绑定挂载，重启 Docker 不会丢失）
# 注意：不要使用 docker compose down -v，否则会删除数据目录内容
DATABASE_URL=mysql+pymysql://bread:bread123@127.0.0.1:3306/bread_testing?charset=utf8mb4

# 桌面应用窗口（python -m app.desktop）
DESKTOP_INIT_URL=http://127.0.0.1:8000/static/desktop/index.html
DESKTOP_TITLE=
DESKTOP_WIDTH=1280
DESKTOP_HEIGHT=800
DESKTOP_RESIZABLE=false
DESKTOP_FRAMELESS=true
DESKTOP_EASY_DRAG=true
DESKTOP_BACKGROUND_COLOR=#020617
DESKTOP_DISABLE_TOUCH_SCROLL=true
DESKTOP_ZOOMABLE=false
